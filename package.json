{
  "name": "fiscalismia-backend",
  "version": "0.9.2",
  "description": "server running the fiscalismia backend express server and REST API",
  "main": "server.js",
  "scripts": {
    "build": "tsc",
    "typeCheck": "node src/tests/typeCheck",
    "eslintAnalysis": "node src/tests/eslintAnalysis",
    "snykCodeAnalysis": "node src/tests/snykCodeAnalysis",
    "snykDependencyAnalysis": "node src/tests/snykDependencyAnalysis",
    "lint": "eslint .",
    "prod": "cross-env NODE_ENV=production CLOUD_DB=true node dist/server.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.ts --ignore tests/",
    "neon-dev": "cross-env NODE_ENV=development CLOUD_DB=true nodemon src/server.ts --ignore tests/",
    "docker-dev": "cross-env NODE_ENV=docker-development nodemon --watch src --legacy-watch --delay 2500ms  src/server.ts --ignore tests/",
    "test": "cross-env NODE_ENV=test jest --forceExit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fiscalismia/fiscalismia-backend.git"
  },
  "keywords": [
    "fiscalis",
    "libertas",
    "autonomia"
  ],
  "author": "hangrybear666",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fiscalismia/fiscalismia-backend/issues"
  },
  "homepage": "https://github.com/fiscalismia/fiscalismia-backend#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "ip": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pg-format": "^1.0.4",
    "serve-favicon": "^2.5.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^48.2.7",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "supertest": "^7.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "volta": {
    "node": "24.14.0"
  }
}
